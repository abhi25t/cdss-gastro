# Byte-compiled / cache
__pycache__/
*.py[cod]
*.pyc

# Virtual environments (project venv lives at /home/ai/pyenv/cdss, outside the repo)
.venv/
venv/
env/

# Test / tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Packaging
*.egg-info/
build/
dist/

# Editor / OS
.vscode/
.idea/
.DS_Store

# Firebase — project-specific config and secret service-account keys
webapp/patient/firebase-config.js
serviceAccountKey.json
*-service-account*.json
.env

# Firebase Hosting — local project binding (keep .firebaserc.example tracked)
.firebaserc

# Firebase CLI local cache (created by `firebase deploy`)
.firebase/

# Generated waiting-room posters (per-doctor: poster_<slug>.png/.pdf, plus poster.*)
webapp/poster.*
webapp/poster_*

# Reference textbooks / large binaries — copyrighted, not for distribution
*.pdf

# Local-only working notes (not for the repo)
CLAUDE.md

# Doctor credentials & registry — emails, SMTP passwords, receptionist contacts,
# dashboard password hashes. NEVER commit (public repo). Only example templates
# and the README are tracked; all real files are ignored. This also covers the
# on-prem consultations store (doctors/consultations.db) — patient PHI, never commit.
doctors/*
!doctors/*.example.yaml
!doctors/README.md
